# 環境變數範本檔案
# 使用方式：複製此檔案並命名為 .env.local，再填入你的實際金鑰
# 注意：.env.local 已加入 .gitignore，絕對不能提交到 Git！

# Firebase 設定 — 從 Firebase 控制台 > 專案設定 > 你的應用程式 複製
# NEXT_PUBLIC_ 前綴讓這些變數可以在瀏覽器端讀取（否則只有伺服器端才能讀）
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Alpha Vantage 股票報價 API — 免費方案申請：https://www.alphavantage.co/support/#api-key
# 用於 /api/prices 路由查詢每日收盤價（免費方案每天限 25 次請求）
# 若省略或使用 "demo"，只能查詢 MSFT 的範例資料
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
